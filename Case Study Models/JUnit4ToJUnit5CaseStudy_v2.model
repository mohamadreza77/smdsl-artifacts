      <nestedFeatures name="ParameterResolver" xmi:id="_f00135"/>
      <nestedFeatures name="ExecutionCondition" xmi:id="_f00136"/>
      <nestedFeatures name="TestWatcher extension" xmi:id="_f00137"/>
