      <nestedFeatures xmi:id="_Jgtu8MWjEfCIz4WBK8SiNA" name="Domain Class"/>
      <nestedFeatures xmi:id="_Qcvs8MWjEfCIz4WBK8SiNA" name="Semantic Candidates Expressionn"/>
      <nestedFeatures xmi:id="_qjV-QNX9EfCr3byAh3mwFQ" name="Id"/>
    </features>
    <features xmi:id="_k-zRAMV9EfCIz4WBK8SiNA" name="Style">
      <nestedFeatures xmi:id="_-YYdsMWkEfCIz4WBK8SiNA" name="Color"/>
      <nestedFeatures xmi:id="__d4tMMWkEfCIz4WBK8SiNA" name="Label Color"/>
      <nestedFeatures xmi:id="_BPsCAMWlEfCIz4WBK8SiNA" name="Border Color"/>
      <nestedFeatures xmi:id="_EzpQ8MWlEfCIz4WBK8SiNA" name="Allow Resizing"/>
      <nestedFeatures xmi:id="_nc71oMWkEfCIz4WBK8SiNA" name="Label Size"/>
      <nestedFeatures xmi:id="_qeWYMMWkEfCIz4WBK8SiNA" name="Label Format"/>
