rule Platform2FeatureHierarchyV2
  transform p : smdsl_updated_updated_package::Platform {

  template  : "featureHierarchy_v2.egl"

  parameters : Map{
    "path"     = Sequence{"Platforms", p.name, "Feature Hierarchy"},
    "icon"     = "diagram-aaaaaa",
    "format"   = "graphviz-dot",
    "platform" = p
  }
}

