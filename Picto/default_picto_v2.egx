rule Transformation2DetailV2
  transform c : smdsl_updated_updated_package::Transformation {
  guard : c.eContainer().isDefined() and c.eContainer().eClass().name = "Mapping"

  template : "default_correspondenceDetail_v2.egl"

  parameters : Map{
    "path"  = Sequence{"Correspondences", c.eContainer().name, "Transformations", c.name},
    "icon"   = "source",
    "format" = "markdown",
    "correspondence" = c,
    "migration"      = c.eContainer().eContainer()
  }
}

rule Preservation2DetailV2
  transform c : smdsl_updated_updated_package::Preservation {
  guard : c.eContainer().isDefined() and c.eContainer().eClass().name = "Mapping"

