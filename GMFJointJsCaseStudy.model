      <strategy xmi:id="_geIogOYGEfC9Me990hLAnQ">
        <steps xmi:id="_iOR4YOZyEfCbGf1_nr27lg" description="take the name (A) of polyline" order="1"/>
        <steps xmi:id="_jwJTwOZyEfCbGf1_nr27lg" description="take the most top parent shape (B) of polyline" order="2"/>
        <steps xmi:id="_j0C8UOZyEfCbGf1_nr27lg" description="take the node (C) that its figure property refers to B" order="3"/>
        <steps xmi:id="_kVif0OZyEfCbGf1_nr27lg" description="take the node mappings (D) that refers to C" order="4"/>
        <steps xmi:id="_kgytkOZyEfCbGf1_nr27lg" description="take all the Ds' Dia Element equivalents" order="5"/>
        <steps xmi:id="_k50RkOZyEfCbGf1_nr27lg" description="for every Dia Element (E) in D" order="6" type="-">
          <nestedSteps xmi:id="_4B0yUOZ0EfCbGf1_nr27lg" description="check if E has an object in attrs with the name being A (X)" order="1"/>
          <nestedSteps xmi:id="_Hm0xQOZ1EfCbGf1_nr27lg" description="if X is true" order="2" type="-">
            <nestedSteps xmi:id="_FZAckOZ6EfCbGf1_nr27lg" description="if not exist, add an object in Visual Structure of E with the tagName and selector being 'path' and A" order="1"/>
            <nestedSteps xmi:id="_WpxzEOZ1EfCbGf1_nr27lg" description="take the object (F)" order="2"/>
          </nestedSteps>
          <nestedSteps xmi:id="_NX27wOZ1EfCbGf1_nr27lg" description="else" order="3" type="-">
            <nestedSteps xmi:id="_cZDtQOZ5EfCbGf1_nr27lg" description="add an object to Visual Structure of E with the tagName and selector being 'path' and A" order="1"/>
            <nestedSteps xmi:id="_OjeaUOZ1EfCbGf1_nr27lg" description="add an object (F) to attrs of Visual Attributes of E with the name being A" order="2"/>
          </nestedSteps>
          <nestedSteps xmi:id="_gLdLYOZ6EfCbGf1_nr27lg" description="take the tamplate points (G) of polyline (in the same order they listed)" order="4"/>
        </steps>
      </strategy>
      <subcorrespondences xmi:id="_lv7ygOZ4EfCbGf1_nr27lg" name="Computing Path Data" sourceFeature="_aW-9QOZ4EfCbGf1_nr27lg" targetFeature="_RkZ_QOZ2EfCbGf1_nr27lg">
        <complexity xsi:type="mgem_core_prefix:FullAutomation" xmi:id="_tWKkEOZ4EfCbGf1_nr27lg"/>
        <strategy xmi:id="_vIcvIOZ6EfCbGf1_nr27lg">
