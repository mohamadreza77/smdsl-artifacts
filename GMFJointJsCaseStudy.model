          <steps xmi:id="_f7R5AOaIEfCbGf1_nr27lg" description="take the first template point x and y" order="2"/>
          <steps xmi:id="_MQx6wOZ8EfCbGf1_nr27lg" description="put a 'M x y ' string (I) for H" order="3"/>
