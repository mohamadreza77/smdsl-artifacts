  <operators xmi:id="_tCufwMZwEfCeR8oIST4D4w" name="Mr. X"/>
  <mappings xmi:id="_1C_R4MVzEfCIz4WBK8SiNA" name="Node Definition - Structural">
    <correspondences xmi:id="_Q3mlMMcdEfCBo5CuJG-9rA" name="Node Mapping to Dia Element" sourceFeature="_3AY-UMcWEfCBo5CuJG-9rA" targetFeature="_QiCToNI7EfCGnY31vy1jEg _XjLwQNI9EfCGnY31vy1jEg" relation="A GMF Node Mapping specifies how a semantic element is represented as a node in the diagram, including its identity and containment context. In JointJS, this responsibility is realized by defining a Dia Element, whose type and uniqueness are determined through its namespace. Since both constructs serve to introduce a concrete node type tied to a domain element, the mapping is direct and can be fully automated, with namespace composition systematically derived from the GMF mapping context.">
      <complexity xsi:type="mgem_core_prefix:FullAutomation" xmi:id="_R_tboMiwEfCBo5CuJG-9rA"/>
      <strategy xmi:id="_WeTAkMcgEfCBo5CuJG-9rA">
        <steps xmi:id="_X66WUMjSEfCBo5CuJG-9rA" description="take the element property (A) of the node mapping" order="1"/>
        <steps xmi:id="_Qo34ENb0EfC3pJN73lPkbQ" description="take the parent top node/child reference (B) of the node mapping" order="2"/>
        <steps xmi:id="_COLQMNeQEfCUYJN3_L4-Ew" description="check if B has the compartment property (X)" order="3"/>
        <steps xmi:id="_HhztANeQEfCUYJN3_L4-Ew" description="if X is true" order="4" type="-">
          <nestedSteps xmi:id="_bLydMNb0EfC3pJN73lPkbQ" description="take the compartment property (C) of B" order="1"/>
          <nestedSteps xmi:id="_1wkqkNeQEfCUYJN3_L4-Ew" description="take the name property (D) of C" order="2"/>
          <nestedSteps xmi:id="_zrlaIMcgEfCBo5CuJG-9rA" description="if not already exist, create a dia element with the var name 'A_D' (E), else 'A_D_i' (E) where i is a counter computed by the last i + 1" order="3"/>
          <nestedSteps xmi:id="_j6UxANLKEfCGnY31vy1jEg" description="paste 'custom.E' into the namespace of dia element" order="4"/>
        </steps>
        <steps xmi:id="_jmPoINeQEfCUYJN3_L4-Ew" description="if X is false" order="5" type="-">
          <nestedSteps xmi:id="_mNDSUNeQEfCUYJN3_L4-Ew" description="if not already exist, create a dia element with the var name 'A' (E), else 'A_i' (E) where i is a counter computed by the last i + 1 " order="1"/>
          <nestedSteps xmi:id="_mNDSUdeQEfCUYJN3_L4-Ew" description="paste 'custom.E' into the namespace of dia element" order="2"/>
        </steps>
      </strategy>
    </correspondences>
    <correspondences xmi:id="_l_gxMMWrEfCIz4WBK8SiNA" name="Compartment Mapping to Dia Visual Properties" sourceFeature="_5xyRUMiqEfCBo5CuJG-9rA" targetFeature="_tXkaoNLiEfCGnY31vy1jEg _HfgTMNLrEfCGnY31vy1jEg _fSDZ0NLUEfCGnY31vy1jEg" relation="A GMF Compartment Mapping introduces a dedicated visual region inside a node used to structure and present contained content. In JointJS, a possible equivalent is to materialize that region inside the element&#x2019;s SVG/markup by defining a sub-shape via tagName and selector, and then controlling its appearance through an obhect in attrs. ">
      <complexity xsi:type="mgem_core_prefix:FullAutomation" xmi:id="_ZtME4MjVEfCBo5CuJG-9rA" difficulty="COMPLEX"/>
      <strategy xmi:id="_m93LoMWyEfCIz4WBK8SiNA">
        <steps xmi:id="_6ZhNoMjUEfCBo5CuJG-9rA" description="take the visual representation compartment property (A) of the compartment mapping" order="1"/>
        <steps xmi:id="_GTLjQMjVEfCBo5CuJG-9rA" description="take the name property (B) of A" order="2"/>
        <steps xmi:id="_uvIWMNeSEfCUYJN3_L4-Ew" description="take the parent node mapping (C) of the compartment mapping" order="3"/>
        <steps xmi:id="_z2CloNeSEfCUYJN3_L4-Ew" description="take the C's equivalent Dia Element" order="4"/>
        <steps xmi:id="_THGYgNLXEfCGnY31vy1jEg" description="add an object to Visual Structure of C with the tagName and selector being 'rect' and B" order="5"/>
        <steps xmi:id="_nyIhMMWyEfCIz4WBK8SiNA" description="add an obejct to attrs of Visual Attributes of C with the name being B" order="6"/>
      </strategy>
      <subcorrespondences xmi:id="_uDalQNLoEfCGnY31vy1jEg" name="Compartment Mapping to Dia Behaviour" sourceFeature="_XwQI0MiuEfCBo5CuJG-9rA" targetFeature="_PmeIYNLtEfCGnY31vy1jEg">
        <complexity xsi:type="mgem_core_prefix:OperatorHelp" xmi:id="_LU1g0NL9EfCGnY31vy1jEg" operators="_tCufwMZwEfCeR8oIST4D4w"/>
        <strategy xmi:id="_FMDfUNLqEfCGnY31vy1jEg">
          <steps xmi:id="_gToDMNLiEfCGnY31vy1jEg" description="take all the child references (D) of the children property" order="1"/>
          <steps xmi:id="_WYK88NeTEfCUYJN3_L4-Ew" description="take all the node mappings (E) of D" order="2"/>
          <steps xmi:id="_RaGYQNLkEfCGnY31vy1jEg" description="take all the Es' equivalent Dia Elements (F)" order="3"/>
          <steps xmi:id="_4G4TQNeTEfCUYJN3_L4-Ew" description="take all the namespaces (G) in F" order="4"/>
          <steps xmi:id="_VnSm4NLjEfCGnY31vy1jEg" description="if not exist, add a function called 'canEmbed' to Behaviour of C" order="5"/>
          <steps xmi:id="_AKkc4NeUEfCUYJN3_L4-Ew" description="add G to the list inside 'canEmbed'" order="6"/>
          <steps xmi:id="_43XpUNLjEfCGnY31vy1jEg" description="if not exist, add a function called 'getCompartmentSelector' to Behaviour" order="7"/>
          <steps xmi:id="_-l7uoNLjEfCGnY31vy1jEg" description="for every namespace (I) in G, add an if statement to 'getCompartmentSelector' in a way that it compares equality between element type and I, and if true, return B" order="8"/>
          <steps xmi:id="_QgHIUNL8EfCGnY31vy1jEg" description="if not exist, create a JavaScript file called 'util.js' with the default implementation of 'autoEmbedAll' and 'restrictTranslate' " order="9"/>
          <steps xmi:id="_ZZaEQNL8EfCGnY31vy1jEg" description="call 'autoEmbedAll' wherever needed to bind sub-nodes and the super-node together" order="10"/>
          <steps xmi:id="_pgAUYNL8EfCGnY31vy1jEg" description="bind 'restrictTranslate' and the restrictTranslate property of paper together" order="11"/>
          <steps xmi:id="_FKXTsP7QEfCSwLIet1pVuQ" description="operators must verify the implementation and binding" order="12" type="M"/>
        </strategy>
      </subcorrespondences>
    </correspondences>
  </mappings>
  <mappings xmi:id="_DUeZYMcHEfCBo5CuJG-9rA" name="Diagram Infrastructure - Structural">
    <correspondences xmi:id="_mr1WQMcMEfCBo5CuJG-9rA" name="Canvas Mapping to Graph/Paper" sourceFeature="_VF96gMcGEfCBo5CuJG-9rA" targetFeature="_LhVX8NGNEfCFdd5sWaqdsQ _M5Q0MNGNEfCFdd5sWaqdsQ" relation="Canvas Mapping in GMF defines the diagram-level entry point, combining both the semantic root of the diagram and its global visual configuration. In JointJS, these responsibilities are intentionally separated: Graph manages the diagram&#x2019;s underlying model, while Paper manages rendering, layout, and interaction. Therefore, a single Canvas Mapping can be realized by coordinating Graph and Paper, making the correspondence valid despite the structural decomposition. ">
      <complexity xsi:type="mgem_core_prefix:OperatorHelp" xmi:id="_j9v9wOwLEfCKspm6e6k1Tg" operators="_tCufwMZwEfCeR8oIST4D4w"/>
      <strategy xmi:id="_pgJwoMcPEfCBo5CuJG-9rA">
        <steps xmi:id="_-sxq4NGNEfCFdd5sWaqdsQ" description="take the element property (A) of the canvas mapping" order="1"/>
        <steps xmi:id="_NaOgYMcSEfCBo5CuJG-9rA" description="create one JavaScript file (name it A.js) with instantiating Graph and Paper, and another JavaScript file (name it A+Elements.js)" order="2"/>
        <steps xmi:id="_m9YXoOwLEfCKspm6e6k1Tg" description="supervisors should set the desired Paper's properties such as width, height, drawGrid, gridSize, binding to the HTML element, etc." order="3"/>
      </strategy>
    </correspondences>
  </mappings>
  <mappings xmi:id="_pCcNEMjUEfCBo5CuJG-9rA" name="Layout Semantics - Visual">
    <correspondences xmi:id="_V9CSkNLREfCGnY31vy1jEg" name="Computing Dia Element Width and Height" sourceFeature="_jA3iMNMGEfCGnY31vy1jEg" targetFeature="_kEubcNLQEfCGnY31vy1jEg _lH03MNLQEfCGnY31vy1jEg" relation="Both features are responsible for fixing the concrete spatial extent of a node. GMF Size captures dimensional constraints (preferred, minimum, or maximum) at the figure-definition level. JointJS expresses the same intent more directly by assigning explicit width and height values to Dia Eements. Size constraints defined in GMF can be preserved as explicit geometric properties in the JointJS model. ">
      <complexity xsi:type="mgem_core_prefix:FullAutomation" xmi:id="_gLxXcNLREfCGnY31vy1jEg" difficulty="COMPLEX"/>
      <strategy xmi:id="_Oc2CINLSEfCGnY31vy1jEg">
        <steps xmi:id="_mHDsgNMFEfCGnY31vy1jEg" description="take Dx (A) and Dy (B) of size (preferred/min/max in order)" order="1"/>
        <steps xmi:id="_L6necNiPEfC6eumi-hp08w" description="take the parent shape (C) of size" order="2"/>
        <steps xmi:id="_5w_xMNiPEfC6eumi-hp08w" description="check if C has a figure descriptor parent (X)" order="3"/>
        <steps xmi:id="_BTOMgNiQEfC6eumi-hp08w" description="if X it true" order="4" type="-">
          <nestedSteps xmi:id="_HGl5UNiQEfC6eumi-hp08w" description="take the figure descriptor parent (D)" order="1"/>
          <nestedSteps xmi:id="_OTsZMNiQEfC6eumi-hp08w" description="take the node (E) that refers to D in its figure property" order="2"/>
          <nestedSteps xmi:id="_cjgt4NiQEfC6eumi-hp08w" description="take all the node mappings (F) that refere to E in their diagram node feature" order="3"/>
          <nestedSteps xmi:id="_H5sEENMHEfCGnY31vy1jEg" description="take all the equivalent Dia Elements (G) of F" order="4"/>
          <nestedSteps xmi:id="_IPy28NMHEfCGnY31vy1jEg" description="paste A and B into width and height of the Visual Attributes of G" order="5"/>
        </steps>
      </strategy>
    </correspondences>
    <correspondences xmi:id="_slTtsNLWEfCGnY31vy1jEg" name="Computing Geometry for Attrs" sourceFeature="_WWheYMWQEfCIz4WBK8SiNA" targetFeature="_LK-kwNL-EfCGnY31vy1jEg _LsJYINL-EfCGnY31vy1jEg _MLF98NL-EfCGnY31vy1jEg _L55gQNL-EfCGnY31vy1jEg" relation="Although GMF LayoutData and JointJS refX/refY/refWidth/refHeight are grounded in different layout paradigms, both mechanisms ultimately serve to encode the spatial intent of sub-figures within a container. GMF expresses this intent through nested XY offsets that are resolved imperatively during rendering, whereas JointJS captures the same intent declaratively by anchoring sub-elements relative to their parent&#x2019;s dimensions. ">
      <complexity xsi:type="mgem_core_prefix:OperatorHelp" xmi:id="_TyqocNlCEfC6eumi-hp08w" operators="_tCufwMZwEfCeR8oIST4D4w"/>
      <strategy xmi:id="_ZxWMsNMIEfCGnY31vy1jEg">
        <steps xmi:id="__UMV8Nk9EfC6eumi-hp08w" description="check if LayoutData is a kind of XYLayoutData (X)" order="1"/>
        <steps xmi:id="_FgPogNk-EfC6eumi-hp08w" description="if X is true" order="2" type="-">
          <nestedSteps xmi:id="_LDqi4NlAEfC6eumi-hp08w" description="take XYLayoutData (A)" order="1"/>
          <nestedSteps xmi:id="_wdSWoNk-EfC6eumi-hp08w" description="take the parent (B) of A" order="2"/>
          <nestedSteps xmi:id="_l63rUNk_EfC6eumi-hp08w" description="check if B's most top parent shape has a kind of size (Y)" order="3"/>
          <nestedSteps xmi:id="_qOYH4Nk_EfC6eumi-hp08w" description="if Y is true" order="4" type="-">
            <nestedSteps xmi:id="_sW56oNk_EfC6eumi-hp08w" description="take the size (preferred/min/max in order) of the most top parent shape (C)" order="1"/>
            <nestedSteps xmi:id="_8imtMNk_EfC6eumi-hp08w" description="take Dx (D) and Dy (E) of A" order="2"/>
            <nestedSteps xmi:id="_eqeKYNlAEfC6eumi-hp08w" description="take Dx (F) and Dy (G) of C" order="3"/>
            <nestedSteps xmi:id="_0hWXENlAEfC6eumi-hp08w" description="take Zx=sum of all Xs of the XYLayoutDatas from A to C (H)" order="4"/>
            <nestedSteps xmi:id="_BbqpAOGzEfCreafsdKqYmA" description="take Zy=sum of all Ys of the XYLayoutDatas from A to C (I)" order="5"/>
            <nestedSteps xmi:id="_-PTFkNMKEfCGnY31vy1jEg" description="calc: refWidth= D/F, refHeight= E/G, refX= H/F, refY= I/G" order="6"/>
            <nestedSteps xmi:id="_oQXbsNlCEfC6eumi-hp08w" description="take the descriptor property (J) of B" order="7"/>
            <nestedSteps xmi:id="_5wJFQNlCEfC6eumi-hp08w" description="check if there is a compartment\diagram label (K) that its figure property referes to J and its accessor property referes to a child access that its figure property refers to B (Z)" order="8"/>
            <nestedSteps xmi:id="_k5xd4NlDEfC6eumi-hp08w" description="if Z is true" order="9" type="-">
              <nestedSteps xmi:id="_AhNT8NlEEfC6eumi-hp08w" description="take the compartment\feature label mapping (L) that refers to K" order="1"/>
              <nestedSteps xmi:id="_u04cINlDEfC6eumi-hp08w" description="take the equivalent object (M) of L in attrs" order="2"/>
              <nestedSteps xmi:id="_UgtIQNlEEfC6eumi-hp08w" description="paste refWidth, refHeight, refx, and refY into M" order="3"/>
              <nestedSteps xmi:id="_BV_CUOG0EfCreafsdKqYmA" description="operators should adjust the numbers if there are gaps or needs fine-tuning" order="4" type="M"/>
            </nestedSteps>
            <nestedSteps xmi:id="_MotAoOZ-EfCbGf1_nr27lg" description="else check if there is a node (N) that its figure property refers to the top most parent (W)" order="10"/>
            <nestedSteps xmi:id="_lGzfgOaEEfCbGf1_nr27lg" description="if W is true" order="11" type="-">
              <nestedSteps xmi:id="_makNcOaEEfCbGf1_nr27lg" description="take the node mappings (O) that refers to N" order="1"/>
              <nestedSteps xmi:id="_J2CnkOaFEfCbGf1_nr27lg" description="for every node mapping (P) in O" order="2" type="-">
                <nestedSteps xmi:id="_MeG2AOaFEfCbGf1_nr27lg" description="take P's Dia Element equivalent (Q)" order="1"/>
                <nestedSteps xmi:id="_QNOzIOaFEfCbGf1_nr27lg" description="if not exist, add an object (R) to attrs of Visual Attributes of Q with the name being the name property of B" order="2"/>
                <nestedSteps xmi:id="_pTScIOaGEfCbGf1_nr27lg" description="paste refWidth, refHeight, refx, and refY into R" order="3"/>
                <nestedSteps xmi:id="_pTScIeaGEfCbGf1_nr27lg" description="operators should adjust the numbers if there are gaps or needs fine-tuning" order="4" type="M"/>
              </nestedSteps>
            </nestedSteps>
          </nestedSteps>
        </steps>
      </strategy>
    </correspondences>
