  <mappings xmi:id="_Rx7NkMs9EfC_5dXRuYHIzA" name="Label Semantics - Visual">
    <correspondences xmi:id="_Bhu_UOQlEfCe7dIxmvlV7w" name="Feature Label Mapping to Dia Visual Properties" sourceFeature="_dCYOIMs9EfC_5dXRuYHIzA" targetFeature="_tXkaoNLiEfCGnY31vy1jEg _HfgTMNLrEfCGnY31vy1jEg _fSDZ0NLUEfCGnY31vy1jEg" relation="A GMF Feature Label Mapping specifies which feature is displayed and associates it with a label figure. In JointJS, the same intent is realized by introducing a text sub-element in the element&#x2019;s markup (tagName/selector) and assigning its visual and textual configuration through attrs. ">
      <complexity xsi:type="mgem_core_prefix:FullAutomation" xmi:id="_q-0JMORqEfCh2_WxUtAqMw"/>
      <strategy xmi:id="_rimLsORqEfCh2_WxUtAqMw">
        <steps xmi:id="_sIREkORqEfCh2_WxUtAqMw" description="take the feature to display (A) property of Feature Label Mapping" order="1"/>
        <steps xmi:id="_lEhYMORuEfCh2_WxUtAqMw" description="take the node mapping parent (B) of Feature Label Mapping" order="2"/>
        <steps xmi:id="_CXqiIORvEfCh2_WxUtAqMw" description="take B's Dia Element equivalent (C)" order="3"/>
        <steps xmi:id="_OSsskOR2EfCh2_WxUtAqMw" description="add an object to Visual Structure of C with the tagName and selector being 'text' and 'A+Label'" order="4"/>
        <steps xmi:id="_VCCWkORvEfCh2_WxUtAqMw" description="add an object to attrs of Visual Attributes of C with the name being 'A+Label' " order="5"/>
      </strategy>
    </correspondences>
  </mappings>
  <mappings xmi:id="_32uosOGqEfCreafsdKqYmA" name="Figure Appearance - Visual">
    <correspondences xmi:id="_BO8VQOGrEfCreafsdKqYmA" name="Polyline to Path Data" sourceFeature="_Z09EYMWhEfCIz4WBK8SiNA" targetFeature="_tXkaoNLiEfCGnY31vy1jEg _HfgTMNLrEfCGnY31vy1jEg _fSDZ0NLUEfCGnY31vy1jEg">
